name: Verify Universal Adapter
description: Test Universal Adapter with Terraform and AWS CLI via Docker
version: 2.0

steps:
  - id: check_terraform_version
    mcp: universal
    method: run
    inputs:
      uses: docker://hashicorp/terraform:latest
      cmd:
        - terraform
        - version
        - -json
      output_parser:
        type: json
        query: "terraform_version"

  - id: check_aws_version
    mcp: universal
    method: run
    inputs:
      uses: docker://amazon/aws-cli:latest
      cmd:
        - aws
        - --version

  - id: log_success
    mcp: bbx.logger
    method: info
    inputs:
      message: "Universal Adapter verification completed! Terraform: ${step.check_terraform_version.result}"
