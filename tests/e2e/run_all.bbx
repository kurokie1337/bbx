id: run_all
name: Master E2E Runner (Enterprise)
steps:
  log_start:
    use: logger.info
    args:
      message: "🚀 Starting Enterprise E2E Suite"

  run_basics:
    use: flow.run
    args: { path: tests/e2e/suite_basics.bbx, inputs: { name: "Tester" } }

  run_fs:
    use: flow.run
    args: { path: tests/e2e/suite_fs.bbx }

  run_http:
    use: flow.run
    args: { path: tests/e2e/suite_http.bbx }

  run_http_adv:
    use: flow.run
    args: { path: tests/e2e/suite_http_adv.bbx }

  run_logic:
    use: flow.run
    args: { path: tests/e2e/suite_logic.bbx }

  run_dag:
    use: flow.run
    args: { path: tests/e2e/suite_dag.bbx }

  run_negative:
    use: flow.run
    args: { path: tests/e2e/suite_negative.bbx }

  generate_report:
    use: system.shell
    args:
      command: "echo # Blackbox E2E Test Report > test_report.md && echo - All Suites Passed >> test_report.md && echo - Generated by run_all.bbx >> test_report.md"

  log_end:
    use: logger.info
    args:
      message: "🏆 ALL TESTS PASSED. Report generated."
