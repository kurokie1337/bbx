id: suite_secrets
name: E2E Secrets Suite
steps:
  log_secret:
    use: logger.info
    args:
      message: "Secret value is: ${secrets.TEST_SECRET}"
    
  verify_secret:
    use: logger.info
    args:
      message: "Secret Resolution Verified"
    when: "'SUPER_SECRET_VALUE' == '${secrets.TEST_SECRET}'"
